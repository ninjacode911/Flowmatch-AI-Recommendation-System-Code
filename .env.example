# ========================
# FlowMatch RecSys — Environment Variables
# ========================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── General ──
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── PostgreSQL ──
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=recsys
POSTGRES_PASSWORD=recsys_dev
POSTGRES_DB=recsys

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Qdrant (Vector Database) ──
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=item_embeddings

# ── Model Config ──
EMBEDDING_DIM=384
CANDIDATE_TOP_K=500
FINAL_TOP_K=10

# ── LLM APIs (Phase 3 — leave empty for now) ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
